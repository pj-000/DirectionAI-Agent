# DirectionAI Agent Environment Variables
# Copy to .env and fill in your values

# ── Model API Keys ──────────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Image Generation ─────────────────────────────────────────────────────────
IMAGE_GENERATION_PROVIDER=doubao  # Options: doubao, openai, off
DOUBAO_API_KEY=your_doubao_api_key_here

# ── Frontend Auth ───────────────────────────────────────────────────────────
# Required: Random secret for session security (min 32 chars)
BETTER_AUTH_SECRET=generate_a_random_secret_here_at_least_32_chars

# ── LangGraph ──────────────────────────────────────────────────────────────
LANGGRAPH_API_KEY=  # Optional, for LangSmith tracing

# ── Docker Settings ─────────────────────────────────────────────────────────
PORT=2026
NGINX_CONF=nginx.conf
DEER_FLOW_HOME=./.deer-flow
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock

# ── Package Registry ───────────────────────────────────────────────────────
NPM_REGISTRY=
UV_INDEX_URL=https://pypi.org/simple
